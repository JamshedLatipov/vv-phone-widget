<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:Views="clr-namespace:OrbitalSIP.Views"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="clr-namespace:OrbitalSIP.Services"
             x:Class="OrbitalSIP.Views.ActiveCallView">
  <Border Width="320" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
    <Grid RowDefinitions="*,Auto">
      <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="0,0,0,14">

        <Views:TopBarControl Name="TopBar" Margin="0,0,0,12" />

        <StackPanel Margin="18,0,18,0" Spacing="14">
          <StackPanel HorizontalAlignment="Center" Spacing="10">
            <Grid Width="104" Height="104">
              <Ellipse Fill="#1D2D42" />
              <Ellipse Width="94" Height="94" Fill="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Fill="#F8FAFC" Stretch="Uniform"
                      Data="M12,12A5,5 0 1,0 7,7A5,5 0 0,0 12,12M12,14C8.13,14 5,17.13 5,21H7C7,18.24 9.24,16 12,16C14.76,16 17,18.24 17,21H19C19,17.13 15.87,14 12,14Z" />
              </Viewbox>
              <Ellipse Width="16" Height="16" Fill="#22C55E" Stroke="#0B1320" StrokeThickness="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
            </Grid>

            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Name="CallerLabel" Text="" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" TextAlignment="Center" />
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Name="CallerNumberLabel" Text="" FontSize="14" FontWeight="Medium" Foreground="#8FA6BE" VerticalAlignment="Center" />
                <Button Name="CopyCallerBtn" MinWidth="44" Height="22" CornerRadius="11" Padding="8,0" Background="#1E293B" BorderThickness="0" Foreground="#E2E8F0" FontSize="9" FontWeight="Bold" Content="{i18n:I18n Copy}" VerticalAlignment="Center" />
              </StackPanel>

              <WrapPanel HorizontalAlignment="Center" ItemHeight="20">
                <Border Background="#1E293B" BorderThickness="0" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                  <TextBlock Text="{i18n:I18n OrbitalSip}" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" />
                </Border>
                <Border Background="#1E293B" BorderThickness="0" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                  <TextBlock Text="{i18n:I18n SecureCall}" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" />
                </Border>
                <Border Background="#064E3B" BorderThickness="0" CornerRadius="10" Padding="8,3" Margin="0,0,0,6">
                  <TextBlock Text="{i18n:I18n Live}" FontSize="9" FontWeight="Bold" Foreground="#10B981" />
                </Border>
              </WrapPanel>

              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Ellipse Name="StatusDot" Width="8" Height="8" Fill="#3B82F6" VerticalAlignment="Center" />
                <TextBlock Name="StatusLabel" Text="{i18n:I18n InCall}" FontSize="11" FontWeight="Bold" LetterSpacing="1.4" Foreground="#60A5FA" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="16" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto,*">
              <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Name="TimerMinutesLabel" Text="00" FontSize="30" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" />
                <TextBlock Text="{i18n:I18n Minutes}" FontSize="9" FontWeight="Bold" LetterSpacing="1.5" Foreground="#6E859D" HorizontalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text=":" FontSize="28" FontWeight="Bold" Foreground="#60748A" VerticalAlignment="Center" Margin="8,0" />
              <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Name="TimerSecondsLabel" Text="00" FontSize="30" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" />
                <TextBlock Text="{i18n:I18n Seconds}" FontSize="9" FontWeight="Bold" LetterSpacing="1.5" Foreground="#6E859D" HorizontalAlignment="Center" />
              </StackPanel>
            </Grid>
          </Border>

          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{i18n:I18n AudioActivity}" FontSize="10" FontWeight="Bold" LetterSpacing="1.4" Foreground="#7B92AA" />
              <TextBlock Grid.Column="1" Text="{i18n:I18n Live}" FontSize="10" FontWeight="Bold" Foreground="#60A5FA" />
            </Grid>
            <Border Background="#0F1A28" BorderBrush="#1B2B3F" BorderThickness="1" CornerRadius="14" Padding="14,12">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="5" Height="12" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="22" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="16" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="28" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="14" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="24" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="10" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="19" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="26" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
                <Border Width="5" Height="15" Background="#3B82F6" CornerRadius="3" Margin="2,0" VerticalAlignment="Center" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{i18n:I18n TalkScript}" FontSize="10" FontWeight="Bold" LetterSpacing="1.4" Foreground="#7B92AA" />
              <TextBlock Grid.Column="1" Text="{i18n:I18n OrbitalPrompt}" FontSize="10" FontWeight="SemiBold" Foreground="#60A5FA" />
            </Grid>
            <Border Background="#101A28" BorderBrush="#1B2B3F" BorderThickness="1" CornerRadius="14" Padding="14,12">
              <TextBlock TextWrapping="Wrap" FontSize="12" FontStyle="Italic" Foreground="#CBD5E1">
                <Run Text="&quot;Hello, thanks for calling Orbital SIP support. I have your session open and I&apos;m ready to help you.&quot;" />
              </TextBlock>
            </Border>
          </StackPanel>

          <UniformGrid Columns="4" Rows="1" Margin="0,2,0,0">
            <Border Margin="4" Background="#1E293B" BorderThickness="0" CornerRadius="14" Padding="10,10,10,8">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Button Name="MuteBtn"
                        Width="42" Height="42" CornerRadius="21"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                  <materialIcons:MaterialIcon Name="MuteIcon" Kind="Microphone" Width="20" Height="20" Foreground="#DDE7F3" />
                </Button>
                <TextBlock Name="MuteLabel" Text="Mute" FontSize="10" FontWeight="Bold" Foreground="#DDE7F3" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <Border Margin="4" Background="#1E293B" BorderThickness="0" CornerRadius="14" Padding="10,10,10,8">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Button Name="HoldBtn"
                        Width="42" Height="42" CornerRadius="21"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                  <materialIcons:MaterialIcon Name="HoldIcon" Kind="Pause" Width="20" Height="20" Foreground="#FFFFFF" />
                </Button>
                <TextBlock Name="HoldLabel" Text="{i18n:I18n Hold}" FontSize="10" FontWeight="Bold" Foreground="#60A5FA" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <Border Margin="4" Background="#1E293B" BorderThickness="0" CornerRadius="14" Padding="10,10,10,8">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Button Name="KeypadBtn"
                        Width="42" Height="42" CornerRadius="21"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                  <materialIcons:MaterialIcon Kind="Dialpad" Width="20" Height="20" Foreground="#DDE7F3" />
                </Button>
                <TextBlock Text="{i18n:I18n Keypad}" FontSize="10" FontWeight="Bold" Foreground="#DDE7F3" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <Border Margin="4" Background="#1E293B" BorderThickness="0" CornerRadius="14" Padding="10,10,10,8">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Button Name="TransferBtn"
                        Width="42" Height="42" CornerRadius="21"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                  <materialIcons:MaterialIcon Kind="Transfer" Width="20" Height="20" Foreground="#DDE7F3" />
                </Button>
                <TextBlock Text="{i18n:I18n Transfer}" FontSize="10" FontWeight="Bold" Foreground="#DDE7F3" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </UniformGrid>

          <Border Name="TransferPanel" IsVisible="False"
                  Background="#0F1A28" BorderBrush="#1B2B3F" BorderThickness="1"
                  CornerRadius="14" Padding="14,12" Margin="0,0,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="{i18n:I18n TransferToOperator}" FontSize="9" FontWeight="Bold"
                         LetterSpacing="1.4" Foreground="#7B92AA" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Name="TransferNumberBox"
                         Margin="0,0,8,0"
                         Background="#152132"
                         BorderBrush="#1D3050"
                         BorderThickness="1"
                         CornerRadius="10"
                         Padding="10,6"
                         FontSize="13"
                         Foreground="#F8FAFC"
                         CaretBrush="#60A5FA"
                         Watermark="{i18n:I18n OperatorNumber}" />
                <Button Name="TransferConfirmBtn"
                        Grid.Column="1"
                        Width="74" Height="34"
                        CornerRadius="10"
                        Background="#1E4270"
                        BorderThickness="0"
                        Foreground="#60A5FA"
                        FontSize="11"
                        FontWeight="Bold"
                        Content="{i18n:I18n Transfer}"
                        HorizontalContentAlignment="Center" />
              </Grid>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
            <Button Grid.Column="0" Name="CreateLeadBtn"
                    Margin="0,0,6,0"
                    Background="#1E293B"
                    BorderThickness="0"
                    CornerRadius="14"
                    Padding="12,12"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="{i18n:I18n Lead}" FontSize="12" FontWeight="Bold" Foreground="#60A5FA" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Grid.Column="1" Name="ScriptBtn"
                    Margin="0,0,6,0"
                    Background="#1E293B"
                    BorderThickness="0"
                    CornerRadius="14"
                    Padding="12,12"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="{i18n:I18n Script}" FontSize="12" FontWeight="Bold" Foreground="#60A5FA" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Grid.Column="2" Name="HangupBtn"
                    Margin="6,0,0,0"
                    Background="#EF4444"
                    BorderThickness="0"
                    CornerRadius="14"
                    Padding="12,12"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <materialIcons:MaterialIcon Kind="PhoneHangup" Width="20" Height="20" Foreground="#FFFFFF" VerticalAlignment="Center" />
                <TextBlock Text="{i18n:I18n EndCall}" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>

          <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="14" Padding="12,10">
            <Grid ColumnDefinitions="*,*">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <materialIcons:MaterialIcon Kind="CheckCircleOutline" Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center" />
                <TextBlock Text="{i18n:I18n SignalStable}" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <materialIcons:MaterialIcon Kind="ShieldCheckOutline" Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center" />
                <TextBlock Text="{i18n:I18n Encrypted}" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </Border>

          <TextBlock Name="TimerLabel" Text="00:00" IsVisible="False" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
    <Views:BottomNavControl Grid.Row="1" Name="BottomNav" />
  </Grid>
  </Border>
</UserControl>
