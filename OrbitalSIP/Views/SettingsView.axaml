<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.SettingsView"
             Background="#0F172A">
  <Border Padding="20">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
        <Button Name="BackBtn" Grid.Column="0"
                Width="36" Height="36" CornerRadius="18"
                Background="#1E293B" BorderThickness="0" Padding="0">
          <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                    Width="18" Height="18" Foreground="#FFFFFF" />
        </Button>
        <TextBlock Grid.Column="1" Text="Settings"
                   FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Grid>

      <!-- Content -->
      <ScrollViewer Grid.Row="1">
        <StackPanel Spacing="16">

          <!-- Backend URL -->
          <StackPanel Spacing="4">
            <TextBlock Text="Backend URL" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="BackendUrlBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="https://api.example.com"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Divider -->
          <Border Height="1" Background="#1A2D42" Margin="0,4,0,4" />

          <!-- SIP Server -->
          <StackPanel Spacing="4">
            <TextBlock Text="SIP Server" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="ServerBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="sip.example.com"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Port -->
          <StackPanel Spacing="4">
            <TextBlock Text="Port" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="PortBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="5060"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Username -->
          <StackPanel Spacing="4">
            <TextBlock Text="Username" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="UsernameBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="1001"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Display Name -->
          <StackPanel Spacing="4">
            <TextBlock Text="Display Name" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="DisplayNameBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="John Doe"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Password -->
          <StackPanel Spacing="4">
            <TextBlock Text="Password" FontSize="11" Foreground="#5F7A96" />
            <Border Background="#1E293B" CornerRadius="8">
              <TextBox Name="PasswordBox"
                       Background="Transparent" Foreground="#FFFFFF"
                       BorderThickness="0" Padding="12,10"
                       Watermark="••••••••"
                       PasswordChar="●"
                       CaretBrush="#17E0A0" />
            </Border>
          </StackPanel>

          <!-- Transport -->
          <StackPanel Spacing="4">
            <TextBlock Text="Transport" FontSize="11" Foreground="#5F7A96" />
            <ComboBox Name="TransportBox"
                      Background="#1E293B" Foreground="#FFFFFF"
                      BorderThickness="1" BorderBrush="#334155"
                      CornerRadius="8"
                      Padding="12,10"
                      HorizontalAlignment="Stretch">
              <ComboBoxItem Content="UDP" />
              <ComboBoxItem Content="TCP" />
              <ComboBoxItem Content="TLS" />
            </ComboBox>
          </StackPanel>

          <!-- Divider -->
          <Border Height="1" Background="#1A2D42" Margin="0,4,0,4" />

          <!-- Speaker -->
          <StackPanel Spacing="4">
            <TextBlock Text="Speaker / Output" FontSize="11" Foreground="#5F7A96" />
            <ComboBox Name="SpeakerBox"
                      Background="#1E293B" Foreground="#FFFFFF"
                      BorderThickness="1" BorderBrush="#334155"
                      CornerRadius="8"
                      Padding="12,10"
                      HorizontalAlignment="Stretch" />
          </StackPanel>

          <!-- Microphone -->
          <StackPanel Spacing="4">
            <TextBlock Text="Microphone / Input" FontSize="11" Foreground="#5F7A96" />
            <ComboBox Name="MicBox"
                      Background="#1E293B" Foreground="#FFFFFF"
                      BorderThickness="1" BorderBrush="#334155"
                      CornerRadius="8"
                      Padding="12,10"
                      HorizontalAlignment="Stretch" />
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <!-- Save button + status -->
      <StackPanel Grid.Row="2" Margin="0,16,0,0" Spacing="8">
        <Button Name="SaveBtn"
                Height="44" CornerRadius="10"
                Background="#10B981" Foreground="#FFFFFF"
                FontWeight="SemiBold" FontSize="14"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Content="Save" />
        <TextBlock Name="StatusLabel" Text="" FontSize="11"
                   Foreground="#FF6B6B" TextWrapping="Wrap"
                   HorizontalAlignment="Center" IsVisible="False" />
      </StackPanel>

    </Grid>
  </Border>
</UserControl>
