<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="clr-namespace:OrbitalSIP.Services"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OrbitalSIP.Views.StatusPopupControl">

    <UserControl.Styles>
        <!-- Status card -->
        <Style Selector="RadioButton.status-card">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1.5" CornerRadius="8" Padding="10,9"
                            HorizontalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.status-card:checked /template/ Border">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Background" Value="#172033"/>
        </Style>
        <Style Selector="RadioButton.status-card:pointerover /template/ Border">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>

        <!-- Duration chip -->
        <Style Selector="RadioButton.dur-chip">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#3D5473"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="7" Margin="1" Padding="4,10">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.dur-chip:checked">
            <Setter Property="Background" Value="#1E3A8A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="RadioButton.dur-chip:pointerover">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="Foreground" Value="#93C5FD"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#0B1120" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12"
            Padding="16" Width="280" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="14">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{i18n:I18n Availability}" FontSize="11" FontWeight="Bold"
                           Foreground="#5F7A96" LetterSpacing="1" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Name="CancelBtn"
                        Width="26" Height="26" CornerRadius="13"
                        Background="#1E293B" BorderThickness="0" Padding="0">
                    <materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" Foreground="#5F7A96"/>
                </Button>
            </Grid>

            <!-- Active Status Banner (shown when paused) -->
            <Border Name="ActiveStatusPanel" IsVisible="False"
                    Background="#0F2040" BorderBrush="#3B82F6" BorderThickness="1"
                    CornerRadius="8" Padding="10,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Viewbox Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Path Fill="#60A5FA" Stretch="Uniform"
                              Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 1,1 20,12A8,8 0 0,1 12,20M12.5,7H11V13L16.2,16.2L17,14.9L12.5,12.2V7Z"/>
                    </Viewbox>
                    <TextBlock Grid.Column="1" Name="ActiveStatusText" Text=""
                               FontSize="12" FontWeight="SemiBold" Foreground="#93C5FD"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Name="EndNowBtn" Content="{i18n:I18n EndNow}"
                            Background="Transparent" Foreground="#60A5FA"
                            FontSize="11" FontWeight="Bold"
                            VerticalAlignment="Center" BorderThickness="0" Padding="6,0,0,0"/>
                </Grid>
            </Border>

            <!-- Status Grid (2 columns) -->
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                <!-- Online -->
                <RadioButton Grid.Row="0" Grid.Column="0"
                             GroupName="StatusGroup" Name="StatusOnline" Tag="online" IsChecked="True"
                             Classes="status-card" Background="#0D1B2E" BorderBrush="#1E3A5F"
                             Margin="0,0,4,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="{i18n:I18n Online}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <!-- Offline -->
                <RadioButton Grid.Row="0" Grid.Column="1"
                             GroupName="StatusGroup" Name="StatusOffline" Tag="offline"
                             Classes="status-card" Background="#0D1B2E" BorderBrush="#1E3A5F"
                             Margin="4,0,0,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center"/>
                        <TextBlock Text="{i18n:I18n Offline}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <!-- Lunch -->
                <RadioButton Grid.Row="1" Grid.Column="0"
                             GroupName="StatusGroup" Name="StatusLunch" Tag="lunch"
                             Classes="status-card" Background="#0D1B2E" BorderBrush="#1E3A5F"
                             Margin="0,0,4,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                            <Path Fill="#F59E0B" Stretch="Uniform"
                                  Data="M11,9H9V2H7V9H5V2H3V9C3,11.12 4.66,12.84 6.75,12.97V22H9.25V12.97C11.34,12.84 13,11.12 13,9V2H11V9M16,6V14H18.5V22H21V2C18.24,2 16,4.24 16,6Z"/>
                        </Viewbox>
                        <TextBlock Text="{i18n:I18n Lunch}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <!-- Break -->
                <RadioButton Grid.Row="1" Grid.Column="1"
                             GroupName="StatusGroup" Name="StatusBreak" Tag="break"
                             Classes="status-card" Background="#0D1B2E" BorderBrush="#1E3A5F"
                             Margin="4,0,0,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                            <Path Fill="#38BDF8" Stretch="Uniform"
                                  Data="M2,21H20V19H2M20,8H18V5H20M20,3H4V13A4,4 0 0,0 8,17H14A4,4 0 0,0 18,13V10H20A2,2 0 0,0 22,8V5C22,3.89 21.1,3 20,3Z"/>
                        </Viewbox>
                        <TextBlock Text="{i18n:I18n Break}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <!-- Training (full width) -->
                <RadioButton Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             GroupName="StatusGroup" Name="StatusTraining" Tag="training"
                             Classes="status-card" Background="#0D1B2E" BorderBrush="#1E3A5F"
                             Margin="0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                            <Path Fill="#C084FC" Stretch="Uniform"
                                  Data="M12,3L1,9L12,15L21,10.09V17H23V9M5,13.18V17.18L12,21L19,17.18V13.18L12,17L5,13.18Z"/>
                        </Viewbox>
                        <TextBlock Text="{i18n:I18n Training}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
            </Grid>

            <!-- Duration (only visible for away states) -->
            <StackPanel Name="DurationPanel" IsVisible="False" Spacing="8">
                <Grid ColumnDefinitions="Auto,*">
                    <Viewbox Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Path Fill="#5F7A96" Stretch="Uniform"
                              Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 1,1 20,12A8,8 0 0,1 12,20M12.5,7H11V13L16.2,16.2L17,14.9L12.5,12.2V7Z"/>
                    </Viewbox>
                    <TextBlock Text="{i18n:I18n SetDuration}" FontSize="10" FontWeight="Bold"
                               Foreground="#5F7A96" LetterSpacing="1" VerticalAlignment="Center"/>
                </Grid>
                <Border Background="#0a1222" CornerRadius="10" Padding="3">
                    <UniformGrid Columns="5" Name="DurationGrid">
                        <RadioButton GroupName="DurationGroup" Classes="dur-chip" Tag="0" IsChecked="True">
                            <StackPanel Width="70" Spacing="0" HorizontalAlignment="Center">
                                <TextBlock Text="∞" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="нет" FontSize="8" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="DurationGroup" Classes="dur-chip" Tag="5">
                            <StackPanel Width="70" Spacing="0" HorizontalAlignment="Center">
                                <TextBlock Text="5" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="мин" FontSize="8" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="DurationGroup" Classes="dur-chip" Tag="10">
                            <StackPanel Width="70" Spacing="0" HorizontalAlignment="Center">
                                <TextBlock Text="10" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="мин" FontSize="8" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="DurationGroup" Classes="dur-chip" Tag="30">
                            <StackPanel Width="70" Spacing="0" HorizontalAlignment="Center">
                                <TextBlock Text="30" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="мин" FontSize="8" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="DurationGroup" Classes="dur-chip" Tag="60">
                            <StackPanel Width="70" Spacing="0" HorizontalAlignment="Center">
                                <TextBlock Text="60" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="мин" FontSize="8" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>
                </Border>
            </StackPanel>

            <!-- Apply button -->
            <Button Name="UpdateStatusBtn"
                    Height="42" CornerRadius="8"
                    Background="#3B82F6" Foreground="#FFFFFF"
                    FontWeight="SemiBold" FontSize="14"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{i18n:I18n UpdateStatus}"/>

        </StackPanel>
    </Border>
</UserControl>
