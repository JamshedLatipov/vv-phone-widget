<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.ExpandedView">
  <Border Width="320"
          Background="#0F172A"
          BorderBrush="#1E293B"
          BorderThickness="1"
          CornerRadius="16"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto" Background="#1E293B">
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="14,12,0,12">
          <Grid Width="34" Height="34">
            <Ellipse Fill="#1D2D42" />
            <Viewbox Width="17" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Fill="#DDE7F3" Stretch="Uniform"
                    Data="M12,12A5,5 0 1,0 7,7A5,5 0 0,0 12,12M12,14C8.13,14 5,17.13 5,21H7C7,18.24 9.24,16 12,16C14.76,16 17,18.24 17,21H19C19,17.13 15.87,14 12,14Z" />
            </Viewbox>
            <Ellipse Name="StatusDot" Width="9" Height="9" Fill="#22C55E" Stroke="#101D2C" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
          </Grid>
          <StackPanel Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="Dialer" FontSize="13" FontWeight="Bold" Foreground="#F8FAFC" />
            <TextBlock Name="StatusLabel" Text="Available" FontSize="10" FontWeight="Medium" Foreground="#89A0B8" />
          </StackPanel>
        </StackPanel>



        <Button Grid.Column="1" Name="CloseBtn"
                Width="28" Height="28" CornerRadius="14"
                Background="#1A2D42" BorderBrush="#2A415B" BorderThickness="1"
          Padding="0" Margin="0,12,10,12"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
          <Viewbox Width="12" Height="12">
            <Path Fill="#9AB0C7" Stretch="Uniform"
                  Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
          </Viewbox>
        </Button>
      </Grid>

      <!-- Dialer display -->
      <Grid Grid.Row="1" Margin="14,10,14,10" ColumnDefinitions="*,Auto,Auto">
        <Border Grid.Column="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12,9">
          <TextBlock Name="DisplayText" Text="" FontSize="22" FontWeight="SemiBold"
                     Foreground="#F8FAFC" HorizontalAlignment="Center"
                     TextTrimming="CharacterEllipsis" LetterSpacing="1.5" MinHeight="30" />
        </Border>
        <Button Grid.Column="1" Name="BackspaceBtn"
                Width="34" Height="34" Margin="8,0,0,0" CornerRadius="17"
                Background="#151F2E" BorderBrush="#28374A" BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
          <Viewbox Width="16" Height="16">
            <Path Fill="#9AB0C7" Stretch="Uniform"
                  Data="M22,3H7L1,12L7,21H22C23.11,21 24,20.11 24,19V5C24,3.89 23.11,3 22,3M19,16.59L17.59,18L13.5,13.91L9.41,18L8,16.59L12.09,12.5L8,8.41L9.41,7L13.5,11.09L17.59,7L19,8.41L14.91,12.5L19,16.59Z" />
          </Viewbox>
        </Button>
        <Button Grid.Column="2" Name="CopyBtn"
                Width="46" Height="34" Margin="6,0,0,0" CornerRadius="17"
                Background="#151F2E" BorderBrush="#28374A" BorderThickness="1"
                Foreground="#DDE7F3" FontSize="10" FontWeight="Bold"
                Content="Copy" />
      </Grid>

      <!-- Numeric keypad -->
      <UniformGrid Grid.Row="2" Name="DialPad" Rows="4" Columns="3" Margin="14,2,14,6">
        <Button Tag="1" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="1" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="2" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="2" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="ABC" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="3" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="3" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="DEF" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="4" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="4" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="GHI" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="5" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="5" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="JKL" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="6" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="6" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="MNO" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="7" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="7" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="PQRS" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="8" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="8" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="TUV" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="9" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="9" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="WXYZ" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="*" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="*" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="0" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="0" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="+" FontSize="10" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="#" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="#" FontSize="21" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
      </UniformGrid>

      <!-- Primary call action -->
      <Button Grid.Row="3" Name="CallBtn"
              Margin="14,10,14,14"
              Height="52" CornerRadius="26"
              Background="#10B981" BorderThickness="0"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Viewbox Width="18" Height="18">
            <Path Fill="#FFFFFF" Stretch="Uniform"
                  Data="M6.62,10.79C8.06,13.62 10.38,15.93 13.21,17.38L15.41,15.18C15.68,14.91 16.08,14.82 16.43,14.94C17.55,15.31 18.76,15.51 20,15.51C20.55,15.51 21,15.96 21,16.51V20C21,20.55 20.55,21 20,21C10.61,21 3,13.39 3,4C3,3.45 3.45,3 4,3H7.5C8.05,3 8.5,3.45 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" />
          </Viewbox>
          <TextBlock Text="Call" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Recent activity -->
      <Border Grid.Row="4" Background="#020617" BorderBrush="#1E293B" BorderThickness="1,1,1,0" Padding="12,7,12,5" MinHeight="60">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="RECENT ACTIVITY" FontSize="10" FontWeight="Bold" LetterSpacing="1.2" Foreground="#7B92AA"/>
            <TextBlock Grid.Column="1" Text="View all" FontSize="10" FontWeight="SemiBold" Foreground="#60A5FA"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
            <Border Width="24" Height="24" CornerRadius="12" Background="#1E293B">
              <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Fill="#22C55E" Stretch="Uniform" Data="M7,7H17V17H7V7M5,5V19H19V5H5Z"/>
              </Viewbox>
            </Border>
            <StackPanel Grid.Column="1" Spacing="0" Margin="8,0,0,0">
              <TextBlock Text="Alice Smith" FontSize="11" FontWeight="SemiBold" Foreground="#E2E8F0"/>
              <TextBlock Text="Today, 10:45 AM" FontSize="9" Foreground="#6E859D"/>
            </StackPanel>
            <Viewbox Grid.Column="2" Width="14" Height="14" VerticalAlignment="Center">
              <Path Fill="#60A5FA" Stretch="Uniform"
                    Data="M6.62,10.79C8.06,13.62 10.38,15.93 13.21,17.38L15.41,15.18C15.68,14.91 16.08,14.82 16.43,14.94C17.55,15.31 18.76,15.51 20,15.51C20.55,15.51 21,15.96 21,16.51V20C21,20.55 20.55,21 20,21C10.61,21 3,13.39 3,4C3,3.45 3.45,3 4,3H7.5C8.05,3 8.5,3.45 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" />
            </Viewbox>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Bottom tab bar -->
      <Border Grid.Row="5" Background="#0F172A" Height="46" BorderBrush="#1E293B" BorderThickness="1,1,1,0">
        <Grid ColumnDefinitions="*,*,*,*">
          <StackPanel Grid.Column="0" Spacing="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Fill="#60A5FA" Stretch="Uniform" Data="M12,19A1,1 0 0,1 13,20A1,1 0 0,1 12,21A1,1 0 0,1 11,20A1,1 0 0,1 12,19M6,19A1,1 0 0,1 7,20A1,1 0 0,1 6,21A1,1 0 0,1 5,20A1,1 0 0,1 6,19M18,19A1,1 0 0,1 19,20A1,1 0 0,1 18,21A1,1 0 0,1 17,20A1,1 0 0,1 18,19M12,13A1,1 0 0,1 13,14A1,1 0 0,1 12,15A1,1 0 0,1 11,14A1,1 0 0,1 12,13M6,13A1,1 0 0,1 7,14A1,1 0 0,1 6,15A1,1 0 0,1 5,14A1,1 0 0,1 6,13M18,13A1,1 0 0,1 19,14A1,1 0 0,1 18,15A1,1 0 0,1 17,14A1,1 0 0,1 18,13M12,7A1,1 0 0,1 13,8A1,1 0 0,1 12,9A1,1 0 0,1 11,8A1,1 0 0,1 12,7M6,7A1,1 0 0,1 7,8A1,1 0 0,1 6,9A1,1 0 0,1 5,8A1,1 0 0,1 6,7M18,7A1,1 0 0,1 19,8A1,1 0 0,1 18,9A1,1 0 0,1 17,8A1,1 0 0,1 18,7M12,1A1,1 0 0,1 13,2A1,1 0 0,1 12,3A1,1 0 0,1 11,2A1,1 0 0,1 12,1M6,1A1,1 0 0,1 7,2A1,1 0 0,1 6,3A1,1 0 0,1 5,2A1,1 0 0,1 6,1M18,1A1,1 0 0,1 19,2A1,1 0 0,1 18,3A1,1 0 0,1 17,2A1,1 0 0,1 18,1Z"/>
            </Viewbox>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.65">
            <Viewbox Width="18" Height="18">
              <Path Fill="#8AA0B8" Stretch="Uniform" Data="M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z"/>
            </Viewbox>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.65">
            <Viewbox Width="18" Height="18">
              <Path Fill="#8AA0B8" Stretch="Uniform" Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M12,6C13.93,6 15.5,7.57 15.5,9.5C15.5,11.43 13.93,13 12,13C10.07,13 8.5,11.43 8.5,9.5C8.5,7.57 10.07,6 12,6M12,20C9.97,20 8.22,19.22 6.92,17.96C8.29,15.42 11.1,14 12,14C12.9,14 15.71,15.42 17.08,17.96C15.78,19.22 14.03,20 12,20Z"/>
            </Viewbox>
          </StackPanel>
          <Button Grid.Column="3" Name="SettingsBtn" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Opacity="0.65">
            <Viewbox Width="18" Height="18">
              <Path Fill="#8AA0B8" Stretch="Uniform" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.35 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.53,11.35 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.68 16.04,18.35 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
            </Viewbox>
          </Button>
        </Grid>
      </Border>

    </Grid>
  </Border>
</UserControl>
