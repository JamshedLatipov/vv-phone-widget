<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:Views="clr-namespace:OrbitalSIP.Views"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.ExpandedView">
  <Border Width="320"
          Background="#0F172A"
          BorderBrush="#1E293B"
          BorderThickness="1"
          CornerRadius="16"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">


      <!-- Header -->
      <Views:TopBarControl Name="TopBar" />

      <!-- Operator Stats Widget -->
      <Views:OperatorStatsControl Grid.Row="1" Name="OperatorStats" />

      <!-- Dialer display -->
      <Grid Grid.Row="2" Margin="14,10,14,10" ColumnDefinitions="*,Auto,Auto">
        <Border Grid.Column="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="12,9">
          <TextBlock Name="DisplayText" Text="" FontSize="22" FontWeight="SemiBold"
                     Foreground="#F8FAFC" HorizontalAlignment="Center"
                     TextTrimming="CharacterEllipsis" LetterSpacing="1.5" MinHeight="30" />
        </Border>
        <Button Grid.Column="1" Name="BackspaceBtn"
                Width="34" Height="34" Margin="8,0,0,0" CornerRadius="17"
                Background="#151F2E" BorderBrush="#28374A" BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
          <Viewbox Width="16" Height="16">
            <Path Fill="#9AB0C7" Stretch="Uniform"
                  Data="M22,3H7L1,12L7,21H22C23.11,21 24,20.11 24,19V5C24,3.89 23.11,3 22,3M19,16.59L17.59,18L13.5,13.91L9.41,18L8,16.59L12.09,12.5L8,8.41L9.41,7L13.5,11.09L17.59,7L19,8.41L14.91,12.5L19,16.59Z" />
          </Viewbox>
        </Button>
        <Button Grid.Column="2" Name="CopyBtn"
                Width="46" Height="34" Margin="6,0,0,0" CornerRadius="17"
                Background="#151F2E" BorderBrush="#28374A" BorderThickness="1"
                Foreground="#DDE7F3" FontSize="10" FontWeight="Bold"
                Content="Copy" />
      </Grid>

      <!-- Numeric keypad -->
      <UniformGrid Grid.Row="3" Name="DialPad" Rows="4" Columns="3" Margin="14,2,14,6">
        <Button Tag="1" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="1" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="2" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="2" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="ABC" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="3" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="3" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="DEF" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="4" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="4" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="GHI" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="5" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="5" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="JKL" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="6" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="6" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="MNO" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="7" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="7" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="PQRS" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="8" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="8" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="TUV" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="9" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="9" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="WXYZ" FontSize="9" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="*" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="*" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="0" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="0" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="+" FontSize="10" FontWeight="Bold" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Tag="#" Background="#1E293B" BorderThickness="0" Margin="6" Height="50" CornerRadius="25" Padding="0" HorizontalAlignment="Stretch">
          <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="#" FontSize="21" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="" FontSize="9" Foreground="#7F96AF" HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>
      </UniformGrid>

      <!-- Primary call action -->
      <Button Grid.Row="4" Name="CallBtn"
              Margin="14,10,14,14"
              Height="52" CornerRadius="26"
              Background="#10B981" BorderThickness="0"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Viewbox Width="18" Height="18">
            <Path Fill="#FFFFFF" Stretch="Uniform"
                  Data="M6.62,10.79C8.06,13.62 10.38,15.93 13.21,17.38L15.41,15.18C15.68,14.91 16.08,14.82 16.43,14.94C17.55,15.31 18.76,15.51 20,15.51C20.55,15.51 21,15.96 21,16.51V20C21,20.55 20.55,21 20,21C10.61,21 3,13.39 3,4C3,3.45 3.45,3 4,3H7.5C8.05,3 8.5,3.45 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" />
          </Viewbox>
          <TextBlock Text="Call" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>


      <!-- Recent activity -->
      <Border Grid.Row="5" Background="#020617" BorderBrush="#1E293B" BorderThickness="1,1,1,0" Padding="12,7,12,5" MinHeight="60">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="RECENT ACTIVITY" FontSize="10" FontWeight="Bold" LetterSpacing="1.2" Foreground="#7B92AA"/>
            <Button Grid.Column="1" Name="RefreshCdrBtn" Width="20" Height="20" Background="Transparent" Padding="0" Margin="0" Cursor="Hand" BorderThickness="0">
                <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Fill="#60A5FA" Stretch="Uniform" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                </Viewbox>
            </Button>
          </Grid>

          <ScrollViewer MaxHeight="200" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl Name="CdrItemsControl">
                  <ItemsControl.ItemTemplate>
                      <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,4">
                            <Border Width="24" Height="24" CornerRadius="12" Background="#1E293B">
                              <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Fill="{Binding IconColor}" Stretch="Uniform" Data="{Binding IconData}"/>
                              </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" Margin="8,0,0,0">
                              <TextBlock Text="{Binding DisplayNumber}" FontSize="11" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                              <TextBlock Text="{Binding DisplayTime}" FontSize="9" Foreground="#6E859D"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Width="24" Height="24"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="5"
                                    Cursor="Hand"
                                    Click="OnCdrCallClicked"
                                    Tag="{Binding DisplayNumber}">
                              <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                <Path Fill="#60A5FA" Stretch="Uniform"
                                      Data="M6.62,10.79C8.06,13.62 10.38,15.93 13.21,17.38L15.41,15.18C15.68,14.91 16.08,14.82 16.43,14.94C17.55,15.31 18.76,15.51 20,15.51C20.55,15.51 21,15.96 21,16.51V20C21,20.55 20.55,21 20,21C10.61,21 3,13.39 3,4C3,3.45 3.45,3 4,3H7.5C8.05,3 8.5,3.45 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" />
                              </Viewbox>
                            </Button>
                          </Grid>
                      </DataTemplate>
                  </ItemsControl.ItemTemplate>
              </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>

      <!-- Bottom tab bar -->
      <Views:BottomNavControl Grid.Row="6" Name="BottomNav" />

    </Grid>
  </Border>
</UserControl>
