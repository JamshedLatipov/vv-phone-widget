<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.ExpandedView">
  <Border Background="#FFFFFFFF" CornerRadius="8" Padding="12" Width="320" Height="240">
    <Grid RowDefinitions="Auto,Auto,*">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Name="CloseBtn" Content="Close" />
      </StackPanel>

      <TextBlock Grid.Row="1" Text="Dial" FontWeight="Bold" Margin="0,8,0,8" />

      <StackPanel Grid.Row="2">
        <TextBox Name="NumberBox" Watermark="Enter number" />
        <WrapPanel Margin="0,8,0,0">
          <Button Content="1" Width="48" Height="48"/>
          <Button Content="2" Width="48" Height="48"/>
          <Button Content="3" Width="48" Height="48"/>
          <Button Content="4" Width="48" Height="48"/>
          <Button Content="5" Width="48" Height="48"/>
          <Button Content="6" Width="48" Height="48"/>
        </WrapPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
