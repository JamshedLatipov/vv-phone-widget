<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.LoginView"
             Background="#0F172A">
  <Border Padding="30">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Logo/Title -->
      <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
        <Panel Width="64" Height="64" Margin="0,0,0,16">
          <Ellipse Fill="#1E293B" />
          <PathIcon Data="M12,2L4,5V11C4,16.07 7.41,20.81 12,22C16.59,20.81 20,16.07 20,11V5L12,2M12,7A3,3 0 0,1 15,10A3,3 0 0,1 12,13A3,3 0 0,1 9,10A3,3 0 0,1 12,7M12,19.2C9.5,19.2 7.29,17.92 6,15.98C6.03,13.97 10,12.9 12,12.9C13.97,12.9 17.97,13.97 18,15.98C16.71,17.92 14.5,19.2 12,19.2Z"
                    Width="32" Height="32" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Panel>
        <TextBlock Text="Orbital SIP" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
        <TextBlock Text="Sign in to your account" FontSize="14" Foreground="#5F7A96" HorizontalAlignment="Center" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Form -->
      <StackPanel Grid.Row="1" Spacing="20" VerticalAlignment="Center">
        <StackPanel Spacing="6">
          <TextBlock Text="Username" FontSize="12" FontWeight="Medium" Foreground="#94A3B8" />
          <Border Background="#1E293B" CornerRadius="8" BorderThickness="1" BorderBrush="#334155">
            <TextBox Name="UsernameBox"
                     Background="Transparent" Foreground="#FFFFFF"
                     BorderThickness="0" Padding="12"
                     Watermark="Enter your username"
                     CaretBrush="#10B981" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Password" FontSize="12" FontWeight="Medium" Foreground="#94A3B8" />
          <Border Background="#1E293B" CornerRadius="8" BorderThickness="1" BorderBrush="#334155">
            <TextBox Name="PasswordBox"
                     Background="Transparent" Foreground="#FFFFFF"
                     BorderThickness="0" Padding="12"
                     Watermark="Enter your password"
                     PasswordChar="●"
                     CaretBrush="#10B981" />
          </Border>
        </StackPanel>

        <Button Name="LoginBtn"
                Height="48" CornerRadius="8"
                Background="#3B82F6" Foreground="#FFFFFF"
                FontWeight="SemiBold" FontSize="16"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Content="Sign In" />

        <TextBlock Name="ErrorLabel" Text="" FontSize="12"
                   Foreground="#EF4444" TextWrapping="Wrap"
                   HorizontalAlignment="Center" IsVisible="False" />
      </StackPanel>

      <!-- Footer -->
      <Button Name="SettingsBtn" Grid.Row="2"
              Background="Transparent" BorderThickness="0"
              HorizontalAlignment="Center" Margin="0,20,0,0">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,13L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                    Width="16" Height="16" Foreground="#94A3B8" />
          <TextBlock Text="Server Settings" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

    </Grid>
  </Border>
</UserControl>
