<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="clr-namespace:OrbitalSIP.Services"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OrbitalSIP.Views.LoginView">
  <Border Width="320"
          Background="#0F172A"
          BorderBrush="#1E293B"
          BorderThickness="1"
          CornerRadius="16"
          ClipToBounds="True"
          Padding="30">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Logo/Title -->
      <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
        <Viewbox Width="72" Height="72" Margin="0,0,0,16">
          <Canvas Width="120" Height="130">
            <Path Stroke="#3B82F6" StrokeThickness="4.5" StrokeLineCap="Round" StrokeJoin="Round"
                  Data="M 10,120 L 10,18 Q 10,10 18,10 L 102,10 Q 110,10 110,18 L 110,102 Q 110,110 102,110 L 30,110" />
            <Path Stroke="#3B82F6" StrokeThickness="4.5" StrokeLineCap="Round" StrokeJoin="Round"
                  Data="M 30,110 L 30,34 Q 30,26 38,26 L 86,26 Q 94,26 94,34 L 94,86 Q 94,94 86,94 L 44,94" />
            <Path Stroke="#3B82F6" StrokeThickness="4.5" StrokeLineCap="Round" StrokeJoin="Round"
                  Data="M 44,94 L 44,48 Q 44,42 50,42 L 72,42 Q 78,42 78,48 L 78,72 Q 78,78 72,78 L 56,78" />
            <Path Stroke="#3B82F6" StrokeThickness="4.5" StrokeLineCap="Round" StrokeJoin="Round"
                  Data="M 56,78 L 56,58 Q 56,55 59,55 L 65,55 Q 68,55 68,58 L 68,65 Q 68,68 65,68 L 60,68" />
          </Canvas>
        </Viewbox>
        <TextBlock FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center">
          <Run Text="PRO" Foreground="#3B82F6" FontWeight="Bold" /><Run Text="FFI" Foreground="#5F7A96" FontWeight="Light" />
        </TextBlock>
        <TextBlock Text="{i18n:I18n SignInAccount}" FontSize="14" Foreground="#5F7A96" HorizontalAlignment="Center" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Form -->
      <StackPanel Grid.Row="1" Spacing="20" VerticalAlignment="Center">
        <StackPanel Spacing="6">
          <TextBlock Text="{i18n:I18n Username}" FontSize="12" FontWeight="Medium" Foreground="#94A3B8" />
          <Border Background="#1E293B" CornerRadius="8" BorderThickness="1" BorderBrush="#334155">
            <TextBox Name="UsernameBox"
                     Background="Transparent" Foreground="#FFFFFF"
                     BorderThickness="0" Padding="12"
                     Watermark="{i18n:I18n EnterUsername}"
                     CaretBrush="#10B981" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="{i18n:I18n Password}" FontSize="12" FontWeight="Medium" Foreground="#94A3B8" />
          <Border Background="#1E293B" CornerRadius="8" BorderThickness="1" BorderBrush="#334155">
            <TextBox Name="PasswordBox"
                     Background="Transparent" Foreground="#FFFFFF"
                     BorderThickness="0" Padding="12"
                     Watermark="{i18n:I18n EnterPassword}"
                     PasswordChar="●"
                     CaretBrush="#10B981" />
          </Border>
        </StackPanel>

        <Button Name="LoginBtn"
                Height="48" CornerRadius="8"
                Background="#3B82F6" Foreground="#FFFFFF"
                FontWeight="SemiBold" FontSize="16"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Content="{i18n:I18n SignIn}" />

        <TextBlock Name="ErrorLabel" Text="" FontSize="12"
                   Foreground="#EF4444" TextWrapping="Wrap"
                   HorizontalAlignment="Center" IsVisible="False" />
      </StackPanel>

      <!-- Footer -->
      <Button Name="SettingsBtn" Grid.Row="2"
              Background="Transparent" BorderThickness="0"
              HorizontalAlignment="Center" Margin="0,20,0,0">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <materialIcons:MaterialIcon Kind="CogOutline" Width="16" Height="16" Foreground="#94A3B8" />
          <TextBlock Text="{i18n:I18n ServerSettings}" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

    </Grid>
  </Border>
</UserControl>
