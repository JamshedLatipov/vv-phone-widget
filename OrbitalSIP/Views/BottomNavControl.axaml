<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OrbitalSIP.Views.BottomNavControl">
  <Border Background="#0F172A" Height="46" BorderBrush="#1E293B" BorderThickness="1,1,1,0" VerticalAlignment="Bottom">
    <Grid ColumnDefinitions="*,*,*,*">
      <Button Grid.Column="0" Name="DialerBtn" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
        <materialIcons:MaterialIcon Name="DialerIcon" Kind="Dialpad" Width="20" Height="20" Foreground="#60A5FA" />
      </Button>
      <Button Grid.Column="1" Name="RecentsBtn" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Opacity="0.65">
        <materialIcons:MaterialIcon Name="RecentsIcon" Kind="ClockOutline" Width="22" Height="22" Foreground="#8AA0B8" />
      </Button>
      <Button Grid.Column="2" Name="ContactsBtn" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Opacity="0.65">
        <materialIcons:MaterialIcon Name="ContactsIcon" Kind="AccountCircleOutline" Width="22" Height="22" Foreground="#8AA0B8" />
      </Button>
      <Button Grid.Column="3" Name="SettingsBtn" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Opacity="0.65">
        <Panel>
          <materialIcons:MaterialIcon Name="SettingsIcon" Kind="CogOutline" Width="22" Height="22" Foreground="#8AA0B8" />
          <!-- Update available indicator dot -->
          <Ellipse Name="UpdateDot" Width="8" Height="8"
                   Fill="#17E0A0"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,0,-1,-1"
                   IsVisible="False" />
        </Panel>
      </Button>
    </Grid>
  </Border>
</UserControl>
