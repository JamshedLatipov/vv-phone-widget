<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.IncomingView">
  <Border Background="#0A1929" CornerRadius="16" Padding="24" Width="300">
    <StackPanel Spacing="4">

      <!-- Label -->
      <TextBlock Text="INCOMING CALL" FontSize="10" FontWeight="Bold"
                 Foreground="#17E0A0" HorizontalAlignment="Center"
                 LetterSpacing="2" />

      <!-- Avatar placeholder -->
      <Ellipse Width="56" Height="56" Margin="0,12,0,12" HorizontalAlignment="Center">
        <Ellipse.Fill>
          <RadialGradientBrush GradientOrigin="0.5,0.4">
            <GradientStop Color="#1A2D42" Offset="0" />
            <GradientStop Color="#0F2540" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>

      <!-- Caller number -->
      <TextBlock Name="CallerText" Text="+1 800 555 0123"
                 FontSize="20" FontWeight="Medium" Foreground="#FFFFFF"
                 HorizontalAlignment="Center" LetterSpacing="1" />

      <!-- Caller name subtitle -->
      <TextBlock Text="Unknown caller" FontSize="12" Foreground="#5F7A96"
                 HorizontalAlignment="Center" Margin="0,2,0,0" />

      <!-- Action buttons -->
      <Grid ColumnDefinitions="*,*" Margin="0,20,0,0">

        <!-- Decline -->
        <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
          <Button Name="DeclineBtn" Width="60" Height="60" CornerRadius="30"
                  Background="#C62828"
                  HorizontalAlignment="Center"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <Viewbox Width="26" Height="26">
              <Canvas Width="24" Height="24">
                <Path Fill="#FFFFFF" Stretch="Uniform"
                      Data="M12 9c-1.6-3.6-1.2-6.4 2.6-6.4C17 2.6 19 4.6 19 7c0 2-.6 3.6-1.4 5l-2-2c.3-.7.4-1.4.4-2 0-1.1-.9-2-2-2-1.6 0-2 .9-2 3L12 9zm5.6 8c-2.5 2.3-5.8 3.6-11.2 0L5 18.4C7 20.8 9.3 22 12 22c2.8 0 5.3-1.3 7-3.4L17.6 17z" />
              </Canvas>
            </Viewbox>
          </Button>
          <TextBlock Text="Decline" FontSize="11" Foreground="#8FA6BE"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Answer -->
        <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center">
          <Button Name="AnswerBtn" Width="60" Height="60" CornerRadius="30"
                  Background="#1B8A4A"
                  HorizontalAlignment="Center"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <Viewbox Width="26" Height="26">
              <Canvas Width="24" Height="24">
                <Path Fill="#FFFFFF" Stretch="Uniform"
                      Data="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C10.61 21 3 13.39 3 4c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
              </Canvas>
            </Viewbox>
          </Button>
          <TextBlock Text="Answer" FontSize="11" Foreground="#8FA6BE"
                     HorizontalAlignment="Center" />
        </StackPanel>

      </Grid>
    </StackPanel>
  </Border>
</UserControl>
