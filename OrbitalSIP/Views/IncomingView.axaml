<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="clr-namespace:OrbitalSIP.Services"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OrbitalSIP.Views.IncomingView">
  <Grid Width="412" Height="108" ClipToBounds="False">
    <Border CornerRadius="32"
            Padding="14,10"
            Background="#F20F172A"
            BorderBrush="#3B82F6"
            BorderThickness="1">

      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <Grid Width="44" Height="44" Margin="0,0,12,0">
          <Ellipse Fill="#FF182231" Width="44" Height="44"/>
          <Ellipse Fill="#FF1E3A5F" Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <materialIcons:MaterialIcon Kind="Account" Width="24" Height="24" Foreground="#FFF8FAFC" HorizontalAlignment="Center" VerticalAlignment="Center" />
          <Ellipse Width="10" Height="10"
                   Fill="#FF22C55E"
                   Stroke="#FF101722"
                   StrokeThickness="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"/>
        </Grid>

        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Name="CallerText"
                       Grid.Column="0"
                       Text="Jonathan Doe"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#FFF8FAFC"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
            <Button Name="CopyCallerBtn"
                    Grid.Column="1"
                    MinWidth="56"
                    Height="24"
                    Margin="8,0,0,0"
                    CornerRadius="12"
                    Padding="10,0"
                    Background="#FF1E293B"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Foreground="#FFE2E8F0"
                    FontSize="10"
                    FontWeight="Bold"
                    Content="{i18n:I18n Copy}"/>
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{i18n:I18n IncomingCall}"
                       FontSize="10"
                       FontWeight="Bold"
                       LetterSpacing="1.8"
                       Foreground="#FF60A5FA"/>
            <TextBlock Name="CallerSubtext"
                       Text="{i18n:I18n OrbitalSip}"
                       FontSize="10"
                       FontWeight="Medium"
                       Foreground="#FF94A3B8"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
            <materialIcons:MaterialIcon Kind="CheckCircle" Width="14" Height="14" Foreground="#FF22C55E" />
            <TextBlock Text="{i18n:I18n Encrypted}"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FF64748B"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0,0,0">
          <Button Name="DeclineBtn"
                  Width="40" Height="40" CornerRadius="20"
                  Background="#FFEF4444"
                  BorderThickness="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <materialIcons:MaterialIcon Kind="PhoneHangup" Width="20" Height="20" Foreground="#FFFFFFFF" />
          </Button>

          <Button Name="AnswerBtn"
                  Width="40" Height="40" CornerRadius="20"
                  Background="#FFF59E0B"
                  BorderThickness="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <materialIcons:MaterialIcon Kind="Phone" Width="20" Height="20" Foreground="#FFFFFFFF" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
