<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.IncomingView">
  <Border Background="#FFFAFAFA" CornerRadius="8" Padding="12" Width="300" Height="160">
    <StackPanel>
      <TextBlock Name="CallerText" Text="Incoming Call" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="+1 800 555 0123" Margin="0,6,0,12"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <Button Name="AnswerBtn" Content="Answer" Width="100" />
        <Button Name="DeclineBtn" Content="Decline" Width="100" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
