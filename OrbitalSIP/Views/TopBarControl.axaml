<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="clr-namespace:OrbitalSIP.Services"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OrbitalSIP.Views.TopBarControl">
  <Grid ColumnDefinitions="*,Auto" Background="#1E293B">
    <Button Name="AvatarBtn" Background="Transparent" BorderThickness="0" Padding="0" Margin="14,12,0,12" HorizontalAlignment="Left">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Grid Width="34" Height="34">
          <Ellipse Fill="#1D2D42" />
          <materialIcons:MaterialIcon Kind="Account" Width="20" Height="20" Foreground="#DDE7F3" HorizontalAlignment="Center" VerticalAlignment="Center" />
          <Ellipse Name="StatusDot" Width="9" Height="9" Fill="#22C55E" Stroke="#101D2C" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
        <StackPanel Spacing="1" VerticalAlignment="Center">
          <TextBlock Name="UsernameLabel" Text="{i18n:I18n Dialer}" FontSize="13" FontWeight="Bold" Foreground="#F8FAFC" />
          <TextBlock Name="StatusLabel" Text="{i18n:I18n Available}" FontSize="10" FontWeight="Medium" Foreground="#89A0B8" />
        </StackPanel>
      </StackPanel>
    </Button>

    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,12,10,12">
      <Button Name="MinimizeBtn"
              Width="28" Height="28" CornerRadius="14"
              Background="#1A2D42" BorderBrush="#2A415B" BorderThickness="1"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center">
        <materialIcons:MaterialIcon Kind="Minus" Width="16" Height="16" Foreground="#9AB0C7" />
      </Button>
      <Button Name="CloseBtn"
              Width="28" Height="28" CornerRadius="14"
              Background="#1A2D42" BorderBrush="#2A415B" BorderThickness="1"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center">
        <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" Foreground="#9AB0C7" />
      </Button>
    </StackPanel>
  </Grid>
</UserControl>
