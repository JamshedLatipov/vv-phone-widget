<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OrbitalSIP.Views.OperatorStatsControl">
  <Border Background="#1C1C1C" CornerRadius="0" Margin="0,0,0,0">
    <StackPanel>
      <!-- Collapsed Header -->

      <Button Name="HeaderButton" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="0">

        <Grid>

          <Grid Name="RatioBarGrid" ColumnDefinitions="0*, 0*, 1*">

            <!-- Green bar for answered -->

            <Border Grid.Column="0" Background="#10B981" Opacity="0.4" />

            <!-- Red bar for missed -->

            <Border Grid.Column="1" Background="#EF4444" Opacity="0.4" />

            <!-- Neutral remaining area -->

            <Border Grid.Column="2" Background="Transparent" />

          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,4">

            <TextBlock Name="SummaryText" Text="0 / 0 вх. 0" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />

            <PathIcon Name="ExpanderIcon" Grid.Column="2" Data="M7,10L12,15L17,10H7Z" Width="12" Height="12" Foreground="#A0A0A0" />

          </Grid>

        </Grid>

      </Button>
      <!-- Expanded Content -->
      <Border Name="ExpandedContent" IsVisible="False" Background="#212121" CornerRadius="0,0,4,4" Padding="12,8">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Name="EfficiencyText" Text="0%" Foreground="#22C55E" FontSize="18" FontWeight="Bold" />
              <TextBlock Text="ЭФФЕКТИВНОСТЬ" Foreground="#A0A0A0" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,0,3" />
            </StackPanel>
            <Button Name="RefreshBtn" Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="4">
                        <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="14" Height="14" Foreground="#A0A0A0" />
            </Button>
          </Grid>
          <!-- 3x3 Grid for stats -->
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*,*" Margin="0,4,0,0">
            <!-- Row 0: Summary -->
            <Border Grid.Row="0" Grid.Column="0" Background="#2C2C2C" CornerRadius="4" Margin="0,0,4,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="TotalCallsText" Text="0" Foreground="#F8FAFC" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ВСЕГО" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Background="#2C2C2C" CornerRadius="4" Margin="2,0,2,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="AvgDurationText" Text="0:00" Foreground="#F8FAFC" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="СР. РАЗГОВОР" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="#2C2C2C" CornerRadius="4" Margin="4,0,0,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="TalkTimeText" Text="0:00" Foreground="#F8FAFC" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="НА ЛИНИИ" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <!-- Row 1: Incoming -->
            <Border Grid.Row="1" Grid.Column="0" Background="#2C2C2C" CornerRadius="4" Margin="0,0,4,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="IncomingCallsText" Text="0" Foreground="#8B5CF6" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ВХОДЯЩИЕ" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" Background="#2C2C2C" CornerRadius="4" Margin="2,0,2,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="IncomingAnsweredText" Text="0" Foreground="#22C55E" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ПРИНЯТО" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" Background="#2C2C2C" CornerRadius="4" Margin="4,0,0,4" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="MissedCallsText" Text="0" Foreground="#EF4444" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ПРОПУЩЕНО" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <!-- Row 2: Outgoing -->
            <Border Grid.Row="2" Grid.Column="0" Background="#2C2C2C" CornerRadius="4" Margin="0,0,4,0" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="OutgoingCallsText" Text="0" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ИСХОДЯЩИХ" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" Background="#2C2C2C" CornerRadius="4" Margin="2,0,2,0" Padding="0,8">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Name="OutgoingAnsweredText" Text="0" Foreground="#22C55E" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="ДОЗВОНИЛСЯ" Foreground="#A0A0A0" FontSize="9" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
